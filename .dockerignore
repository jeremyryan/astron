# Denylist style: exclude only what must not enter the build context. This is
# handled consistently by both Docker and Skaffold's context resolver (the
# previous "ignore-everything then re-include" form was mis-parsed by Skaffold,
# dropping nested sources like cmd/main.go).

# VCS and tooling
.git/
.github/
.devcontainer/

# Build output / binaries
bin/
*.tar

# Go test files (not needed to build the manager)
**/*_test.go

# Web build artifacts and dependencies (the Dockerfile's node stage rebuilds dist)
web/node_modules/
web/dist/
**/*.tsbuildinfo

# Helm vendored subcharts (not used by the image build)
charts/*/charts/

# Local/editor files
*.bak
*.orig
*~
.vscode/
.idea/
Dockerfile.cross
